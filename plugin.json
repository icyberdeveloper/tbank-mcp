{
  "name": "tbank",
  "version": "0.1.1",
  "description": "T-Bank (Т-Банк) MCP — mobile banking API: счета, операции, заказ продуктов, переводы, мессенджер, инвестиции.",
  "author": "icyberdeveloper",
  "homepage": "https://github.com/icyberdeveloper/tbank-mcp",
  "license": "MIT",
  "requirements": {
    "python": ">=3.11",
    "packages": ["mcp>=1.2", "requests>=2.32", "playwright>=1.40"]
  },
  "mcpServers": {
    "tbank": {
      "command": "${REPO_DIR}/.venv/bin/python",
      "args": ["-m", "src.server"],
      "cwd": "${REPO_DIR}"
    }
  },
  "skills": [
    "skills/tbank-login",
    "skills/tbank-grocery-order",
    "skills/tbank-transfer-money",
    "skills/tbank-bill-pay",
    "skills/tbank-budget-analyzer",
    "skills/tbank-invest-advisor"
  ],
  "install": {
    "steps": [
      "python -m venv ${REPO_DIR}/.venv",
      "${REPO_DIR}/.venv/bin/pip install -e ${REPO_DIR}",
      "${REPO_DIR}/.venv/bin/python -m playwright install chromium"
    ]
  }
}
